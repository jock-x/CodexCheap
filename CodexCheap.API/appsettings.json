{
  "ConnectionStrings": {
    "Default": "server=<db-host>;port=3306;uid=<db-user>;pwd=<db-password>;database=codexcheap;charset=utf8mb4;TreatTinyAsBoolean=true;Allow User Variables=True"
  },
  "Jwt": {
    "Secret": "<set-via-Jwt__Secret-environment-variable>",
    "Issuer": "CodexCheap",
    "Audience": "CodexCheap.Admin",
    "ExpiresMinutes": 720
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
